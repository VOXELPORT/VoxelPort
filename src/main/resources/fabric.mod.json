{
  "schemaVersion": 1,
  "id": "voxelport",
  "version": "${version}",
  "name": "VoxelPort",
  "description": "Host Minecraft servers or singleplayer worlds over the internet with VoxelPort room codes. No port forwarding needed.",
  "authors": [
    {
      "name": "VoxelPort",
      "contact": {
        "homepage": "https://github.com/voxelport"
      }
    }
  ],
  "contact": {
    "homepage": "https://github.com/voxelport",
    "sources": "https://github.com/voxelport/voxelport-mod",
    "discord": "https://discord.gg/EuDMWUuGpp"
  },
  "license": "MIT",
  "icon": "assets/voxelport/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.voxelport.mod.VoxelPortMod"
    ],
    "client": [
      "com.voxelport.mod.client.VoxelPortClient"
    ]
  },
  "mixins": [
    "voxelport.mixins.json"
  ],
  "depends": {
    "fabricloader": "${loader_dependency}",
    "minecraft": "${minecraft_dependency}",
    "java": ">=25"
  }
}
